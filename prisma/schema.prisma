generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  password       String
  role           Role
  name           String
  imageLink      String?
  categoryId     String?
  bio            String?
  status         UserStatus       @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  phone          String?
  bookings       Bookings[]
  studentReviews StudentReviews[]
  tutorProfile   TutorProfiles?
  category       Categories?      @relation(fields: [categoryId], references: [id])

  @@map("users")
}

model TutorProfiles {
  id             String           @id @default(uuid())
  userId         String           @unique
  aboutTutor     String
  sessionPrice   Float?
  status         TutorStatus      @default(AVAILABLE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  bookings       Bookings[]
  studentReviews StudentReviews[]
  user           User             @relation(fields: [userId], references: [id])

  @@map("tutor_profiles")
}

model Categories {
  id        String         @id @default(uuid())
  name      String         @unique
  status    CategoryStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  bookings  Bookings[]
  users     User[]

  @@map("categories")
}

model Bookings {
  id         String        @id @default(uuid())
  tutorId    String
  studentId  String
  categoryId String
  date       DateTime
  totalPrice Float?
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  category   Categories    @relation(fields: [categoryId], references: [id])
  student    User          @relation(fields: [studentId], references: [id])
  tutor      TutorProfiles @relation(fields: [tutorId], references: [id])

  @@map("bookings")
}

model StudentReviews {
  id        String        @id @default(uuid())
  tutorId   String
  studentId String
  rating    Int
  comment   String?
  status    ReviewStatus  @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  student   User          @relation(fields: [studentId], references: [id])
  tutor     TutorProfiles @relation(fields: [tutorId], references: [id])

  @@map("student_reviews")
}

enum Role {
  STUDENT
  TUTOR
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TutorStatus {
  AVAILABLE
  UNAVAILABLE
}

enum CategoryStatus {
  COMING_SOON
  ACTIVE
}
